# Azure OpenAI Model
AZURE_OPENAI_API_ENDPOINT=https://<your-openai-resource>.openai.azure.com
AZURE_OPENAI_MODEL=gpt-4.1
# Optional: if omitted, AZURE_OPENAI_MODEL is used
# AZURE_OPENAI_DEPLOYMENT_ID=gpt-4.1

# AI Search
AI_SEARCH_ENDPOINT=https://<your-search-service>.search.windows.net
AI_SEARCH_INDEX_NAME=<your-index-name>
AI_SEARCH_SEMANTIC=semanticConfig
AI_SEARCH_API_VERSION=2025-11-01-preview
# Optional: comma-separated list
AI_SEARCH_FIELDS=contentVector,keywords,summary

# Foundry IQ Objects
KNOWLEDGE_SOURCE_NAME=knowledge-source-index
KNOWLEDGE_BASE_NAME=knowledge-base-ir
# Keep description blank by default
KNOWLEDGE_SOURCE_DESCRIPTION=
KNOWLEDGE_BASE_DESCRIPTION=

# Optional retrieve smoke test
RUN_RETRIEVE_TEST=true
RETRIEVE_TEST_QUERY=Explain the target domain of this knowledge base.
